{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mas-urba",
  "compatibility_date": "2026-02-25",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "masurba-db",
      "database_id": "local-dev-placeholder"
    }
  ],
  "vars": {
    "JWT_SECRET": "mas_urba_secret_key_2024_production"
  }
}
