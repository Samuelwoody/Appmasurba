{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "urbanizaciones-valdemorillo",
  "compatibility_date": "2026-02-25",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "masurba-production",
      "database_id": "0355b25e-d878-48c2-bbcf-6840fb1692a7"
    }
  ],
  "vars": {
    "JWT_SECRET": "mas_urba_secret_key_2024_production"
  }
  // Para producción, añadir DEEPSEEK_API_KEY como secret:
  // npx wrangler secret put DEEPSEEK_API_KEY --project-name urbanizaciones-valdemorillo
}
